{
  "name": "Upfunnel — Entrega material (webhook multi-recurso)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "guia-skills",
        "responseMode": "responseNode",
        "options": {
          "allowedOrigins": "https://recursos.upfunnel.click",
          "ignoreBots": true,
          "rawBody": false
        }
      },
      "id": "webhook",
      "name": "Webhook — form de la página",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        -500,
        300
      ],
      "webhookId": "upfunnel-guia-skills"
    },
    {
      "parameters": {
        "jsCode": "const salida = [];\n\nfor (const item of $input.all()) {\n  const b = item.json.body ?? item.json;\n\n  const nombre   = String(b.nombre   ?? '').trim().slice(0, 80);\n  const whatsapp = String(b.whatsapp ?? '').trim();\n  const correo   = String(b.correo   ?? '').trim().toLowerCase();\n  const trampa   = String(b.web      ?? '').trim();\n  const recurso  = String(b.recurso  ?? 'guia-skills').trim();\n\n  const formatoOk = /^[^\\s@]+@[^\\s@]+\\.[a-z]{2,}$/i.test(correo);\n\n  const desechables = ['mailinator.com','tempmail.com','10minutemail.com','guerrillamail.com','yopmail.com','trashmail.com','sharklasers.com'];\n  const dominio = correo.split('@')[1] || '';\n  const esDesechable = desechables.includes(dominio);\n\n  const soloDigitos = whatsapp.replace(/\\D/g, '');\n  const whatsappOk = soloDigitos.length >= 7 && soloDigitos.length <= 15;\n\n  const esBot = trampa.length > 0;\n\n  const valido = Boolean(nombre) && formatoOk && !esDesechable && whatsappOk && !esBot;\n\n  let motivo = '';\n  if (esBot)             motivo = 'bot';\n  else if (!nombre)      motivo = 'Escribe tu nombre.';\n  else if (!formatoOk)   motivo = 'Ese correo no tiene un formato válido.';\n  else if (esDesechable) motivo = 'Usa un correo real: ahí es donde te llega el material.';\n  else if (!whatsappOk)  motivo = 'Revisa el número de WhatsApp.';\n\n  salida.push({\n    json: {\n      nombre,\n      whatsapp: soloDigitos ? '+' + soloDigitos : '',\n      correo,\n      recurso,\n      valido,\n      motivo,\n      fecha: new Date().toISOString(),\n      origen: 'pagina-clases-upfunnel'\n    }\n  });\n}\n\nreturn salida;"
      },
      "id": "validar",
      "name": "Validar y normalizar",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -280,
        300
      ]
    },
    {
      "parameters": {
